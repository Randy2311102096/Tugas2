<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Web Database Sederhana</title>
    <style>
        body { font-family: sans-serif; margin: 50px; line-height: 1.6; }
        form { margin-bottom: 20px; }
        input { padding: 8px; width: 250px; }
        button { padding: 8px 15px; cursor: pointer; }
        li { margin-bottom: 5px; }
    </style>
</head>
<body>
    <h2>Daftar Tugas Saya</h2>

    <form action="/tambah" method="POST">
        <input type="text" name="item" placeholder="Tulis tugas baru..." required>
        <button type="submit">Tambah</button>
    </form>

    <ul>
       <% daftarTugas.forEach(function(tugas) { %>
        <li style="margin-bottom: 10px;">
            <%= tugas.isi %> 
            <form action="/hapus/<%= tugas.id %>" method="POST" style="display:inline;">
                <button type="submit" style="color: red; margin-left: 10px; cursor: pointer;">
                    Hapus
                </button>
            </form>
        </li>
    <% }); %>
    </ul>
</body>
</html>