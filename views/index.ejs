<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Task Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .container { max-width: 600px; margin-top: 50px; }
        .card { border: none; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .btn-add { border-radius: 0 8px 8px 0; }
        .form-control { border-radius: 8px 0 0 8px; }
        .list-group-item { display: flex; justify-content: space-between; align-items: center; border: none; border-bottom: 1px solid #eee; }
        .list-group-item:last-child { border-bottom: none; }
    </style>
</head>
<body>

<div class="container">
    <div class="card p-4">
        <h2 class="text-center mb-4 text-primary">📝 Daftar Tugas</h2>

        <form action="/tambah" method="POST" class="mb-4">
            <div class="input-group">
                <input type="text" name="item" class="form-control" placeholder="Apa yang ingin dikerjakan?" required>
                <button type="submit" class="btn btn-primary btn-add text-white">Tambah</button>
            </div>
        </form>

        <ul class="list-group list-group-flush">
            <% daftarTugas.forEach(function(tugas) { %>
                <li class="list-group-item">
                    <span class="fw-medium text-dark"><%= tugas.isi %></span>
                    <div>
                        <a href="/edit/<%= tugas.id %>" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                        <form action="/hapus/<%= tugas.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Yakin hapus?')">Hapus</button>
                        </form>
                    </div>
                </li>
            <% }); %>
        </ul>

        <% if (daftarTugas.length === 0) { %>
            <p class="text-center text-muted mt-3">Belum ada tugas. Santai dulu!</p>
        <% } %>
    </div>
</div>

</body>
</html>
